Grammar

    0 $accept: program $end

    1 program: statements

    2 statements: statement
    3           | statements statement

    4 statement: create_table_stmt
    5          | select_stmt

    6 $@1: %empty

    7 create_table_stmt: CREATE TABLE IDENTIFIER $@1 LPAREN create_col_list RPAREN SEMICOLON

    8 create_col_list: create_col_def
    9                | create_col_list COMMA create_col_def

   10 create_col_def: IDENTIFIER data_type

   11 data_type: TYPE_INT
   12          | TYPE_FLOAT
   13          | TYPE_VARCHAR LPAREN INT_VAL RPAREN

   14 $@2: %empty

   15 select_stmt: SELECT $@2 select_col_list FROM table_ref join_clause_list where_clause group_by_clause order_by_clause limit_clause SEMICOLON

   16 select_col_list: ASTERISK
   17                | column_list

   18 column_list: column_item
   19            | column_list COMMA column_item

   20 column_item: IDENTIFIER
   21            | IDENTIFIER DOT IDENTIFIER

   22 table_ref: IDENTIFIER
   23          | IDENTIFIER AS IDENTIFIER
   24          | IDENTIFIER IDENTIFIER

   25 join_clause_list: %empty
   26                 | join_clause_list join_clause

   27 join_clause: JOIN table_ref ON column_item EQUALS column_item

   28 where_clause: %empty
   29             | WHERE condition

   30 condition: column_item rel_op literal
   31          | column_item IN LPAREN literal_list RPAREN
   32          | column_item NOT IN LPAREN literal_list RPAREN
   33          | condition AND condition
   34          | condition OR condition
   35          | NOT condition
   36          | LPAREN condition RPAREN

   37 rel_op: EQUALS
   38       | NOT_EQUALS
   39       | GREATER_EQUAL
   40       | LESS_EQUAL
   41       | GREATER
   42       | LESS

   43 literal: INT_VAL
   44        | FLOAT_VAL
   45        | STRING_VAL

   46 literal_list: literal
   47             | literal_list COMMA literal

   48 group_by_clause: %empty
   49                | GROUP BY column_list

   50 order_by_clause: %empty
   51                | ORDER BY column_list

   52 limit_clause: %empty
   53             | LIMIT INT_VAL


