{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Flex/Bison: Build All",
            "type": "shell",
            "dependsOn": [
                "Bison: Generate Parser",
                "Flex: Generate Lexer",
                "GCC: Compile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Flex: Generate Lexer",
            "type": "shell",
            "command": "C:\\WINFLEXBISON\\win_flex.exe",
            "args": [
                "-o", "${workspaceFolder}\\lex.yy.c",
                "${workspaceFolder}\\lexer.l"
            ],
            "presentation": { "reveal": "silent", "panel": "shared" }
        },
        {
            "label": "Bison: Generate Parser",
            "type": "shell",
            "command": "C:\\WINFLEXBISON\\win_bison.exe",
            "args": [
                "-d", "-v",
                "-o", "${workspaceFolder}\\parser.tab.c",
                "${workspaceFolder}\\parser.y"
            ],
            "presentation": { "reveal": "silent", "panel": "shared" }
        },
        {
            "label": "GCC: Compile",
            "type": "shell",
            "command": "C:\\msys64\\ucrt64\\bin\\gcc.exe",
            "args": [
                "-g",
                "${workspaceFolder}\\lex.yy.c",
                "${workspaceFolder}\\parser.tab.c",
                "-o", "${workspaceFolder}\\program.exe"
            ],
            "presentation": { "reveal": "silent", "panel": "shared" },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "🚀 Build & Run",
            "type": "shell",
            "command": "${workspaceFolder}\\program.exe",
            "dependsOn": ["Flex/Bison: Build All"],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true,
                "clear": true
            },
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "problemMatcher": []
        }
    ]
}